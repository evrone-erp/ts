{
  "extends": "@evrone-erp/eslint-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "src",
    "moduleResolution": "bundler",
    "paths": { "app/*": ["_app/*"] },
    "plugins": [{ "name": "next" }],
    "types": ["@testing-library/jest-dom"],
  },
  "exclude": ["node_modules"],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"]
}
